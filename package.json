        "@types/chrome": "^0.1.38",
        "@types/firefox-webext-browser": "^143.0.0",
        "@types/webextension-polyfill": "^0.12.5",
        "@wxt-dev/module-svelte": "^2.0.5",
        "svelte": "^5.54.1",
        "svelte-check": "^4.4.5",
        "tailwindcss": "^4.2.2",
        "tslib": "^2.8.1",
